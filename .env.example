NEXT_PUBLIC_SIXSHOP_URL=
NEXT_PUBLIC_NAVER_STORE_URL=https://smartstore.naver.com/ycgoldenfarm
NEXT_PUBLIC_CONTACT_ENDPOINT=
NEXT_PUBLIC_SITE_URL=https://w2er1702-boop.github.io/geumbit-farm
# Price visibility on product cards / detail pages.
#   show (default) — list price & sale price, with a "Smartstore 기준" note
#   hide           — hide prices, show "스마트스토어에서 가격 확인" CTA only
NEXT_PUBLIC_PRICE_MODE=show
# Optional Google Analytics 4 measurement id. Unset = no analytics shipped.
# Consent is denied by default (PIPA / GDPR-friendly) until a banner sets it.
NEXT_PUBLIC_GA_ID=
